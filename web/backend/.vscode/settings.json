{
  // Backend-specific Python settings for multi-root workspace
  // This folder is included for navigation and editor features inside the
  // multi-root workspace. Test discovery is centralized at the repository root
  // to avoid duplicate collection in the Testing explorer.
  "python.defaultInterpreterPath": "${workspaceFolder}/../../.venv/bin/python",
  "python.testing.pytestEnabled": false,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestPath": "${workspaceFolder}/../../.venv/bin/pytest",
  "python.testing.cwd": "${workspaceFolder}/../..",
  "python.analysis.extraPaths": [
    "../.."
  ]
}
